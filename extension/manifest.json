{
  "manifest_version": 3,
  "name": "Typenote Moodle Sync",
  "version": "0.1.0",
  "description": "Import course materials from Moodle into Typenote",
  "permissions": [
    "storage",
    "scripting"
  ],
  "optional_host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "dist/service-worker.js"
  },
  "externally_connectable": {
    "matches": [
      "http://localhost:3000/*",
      "https://*.typenote.app/*"
    ]
  },
  "icons": {}
}
