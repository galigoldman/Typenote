{
  "manifest_version": 3,
  "name": "Typenote Moodle Sync",
  "version": "0.2.0",
  "description": "Import course materials from Moodle into Typenote",
  "key": "",
  "permissions": ["storage", "scripting", "cookies", "tabs", "activeTab"],
  "host_permissions": [
    "https://*.typenote.app/*",
    "https://typenote-two.vercel.app/*",
    "http://localhost:3000/*",
    "http://localhost:3001/*"
  ],
  "optional_host_permissions": ["https://*/*"],
  "background": {
    "service_worker": "dist/background/service-worker.js"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Typenote Moodle Sync",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "externally_connectable": {
    "matches": [
      "http://localhost:3000/*",
      "http://localhost:3001/*",
      "http://151.145.83.151:3001/*",
      "https://*.typenote.app/*",
      "https://typenote-two.vercel.app/*"
    ]
  },
  "web_accessible_resources": [
    {
      "resources": ["dist/content/moodle-scraper.js"],
      "matches": ["https://*/*", "http://*/*"]
    }
  ]
}
